#!/bin/bash
SPL_DIR="/home/ug/Desktop/myexpos/spl"
EXPL_DIR="/home/ug/Desktop/myexpos/expl"
STAGE_DIR="/home/ug/Desktop/myexpos/stages/stage25"

# Compile SPL files
if [ -d "$SPL_DIR" ]; then
    cd "$SPL_DIR"
    for file in "$STAGE_DIR/src"/*.spl; do
        if [ -f "$file" ]; then
            output=$(./spl "$file" 2>&1)
            if echo "$output" | grep -iq "syntax error"; then
                echo "$output"
                echo "$file"
            fi
        fi
    done
fi

# Compile EXPL files
if [ -d "$EXPL_DIR" ]; then
    cd "$EXPL_DIR"
    for file in "$STAGE_DIR/src"/*.expl; do
        if [ -f "$file" ]; then
            output=$(./expl "$file" 2>&1)
            if echo "$output" | grep -iq "syntax error"; then
                echo "$output"
                echo "$file"
            fi
        fi
    done
fi

# Move all to stage directory
for file in "$STAGE_DIR/src"/*.xsm; do
    if [ -f "$file" ]; then
        mv "$file" "$STAGE_DIR/"
    fi
done
